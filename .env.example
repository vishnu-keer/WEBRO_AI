# ---------------------------------------------------------------------------
# WEBRO AI Marketing OS — environment variables
# Copy to `.env.local` and fill in. NEVER commit real secrets.
# Validated at boot by src/config/env.ts (fails fast if a required key is missing).
# ---------------------------------------------------------------------------

# --- Supabase (public: safe to expose to the browser) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Supabase (server-only: full DB access, NEVER ships to the browser) ---
SUPABASE_SERVICE_ROLE_KEY=

# --- Claude (reasoning layer) ---
ANTHROPIC_API_KEY=

# --- Firecrawl (web scraping / crawling / search) ---
FIRECRAWL_API_KEY=

# --- Embeddings provider for RAG (default: Voyage AI). See src/lib/rag/embed.ts ---
VOYAGE_API_KEY=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Shared secret the job worker + cron use to authorize /api/jobs/worker calls.
CRON_SECRET=

# --- AI provider: "anthropic" (Claude, paid) or "gemini" (Google, free tier) ---
LLM_PROVIDER=anthropic
# If LLM_PROVIDER=gemini, set this (free key: https://aistudio.google.com/apikey)
GEMINI_API_KEY=
# Optional: override the Gemini model (default: gemini-2.0-flash — free tier:
# ~1,500 requests/day and no "thinking" overhead, so large JSON isn't truncated).
GEMINI_MODEL=
